# ============================================
# Configuración de la Aplicación
# ============================================

# Entorno de ejecución (development, staging, production)
ENVIRONMENT=development
DEBUG=true

# Nombre y versión de la aplicación
APP_NAME="Clean Architecture API"
APP_VERSION=0.1.0
APP_DESCRIPTION="API RESTful construida con FastAPI siguiendo Clean Architecture"

# ============================================
# Configuración del Servidor
# ============================================

# Host y puerto
HOST=0.0.0.0
PORT=8000

# Workers (solo para producción)
WORKERS=4

# ============================================
# Base de Datos
# ============================================

# URL de conexión a la base de datos
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Configuración alternativa (si no se usa DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=database
DB_USER=user
DB_PASSWORD=password

# Pool de conexiones
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ============================================
# Seguridad
# ============================================

# Clave secreta para JWT y sesiones
SECRET_KEY=your-secret-key-change-this-in-production

# Algoritmo de JWT
JWT_ALGORITHM=HS256

# Tiempo de expiración del token (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (separados por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# Logging
# ============================================

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Formato de los logs
LOG_FORMAT=json

# ============================================
# Servicios Externos
# ============================================

# Ejemplo: API de terceros
EXTERNAL_API_KEY=your-api-key
EXTERNAL_API_URL=https://api.example.com/v1
EXTERNAL_API_TIMEOUT=30

# ============================================
# Cache
# ============================================

# URL de Redis (opcional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ============================================
# Testing
# ============================================

# Base de datos para tests
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/test_database

# ============================================
# Notas
# ============================================
# 1. Copiar este archivo a .env y configurar los valores reales
# 2. NUNCA commitear el archivo .env (debe estar en .gitignore)
# 3. En producción, usar secret management apropiado
# 4. Generar SECRET_KEY segura para producción: openssl rand -hex 32
